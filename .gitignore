.env
.env.local
.env.*.local
*.key
*.pem
secrets.json

# Build output / temp
*.tmp
*.log
*.bak

# n8n local data (if you ever export from a self-hosted instance into this repo)
.n8n/

# OS-level archives that shouldn't be tracked
*.zip
*.tar
*.tar.gz
