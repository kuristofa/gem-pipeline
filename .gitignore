# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Python (for build_workflow.py)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Node (in case you add tooling later)
node_modules/
